# WeChat Radar public environment template.
# Copy to .env.local and fill only local paths/keys you actually need.
# Never commit .env.local or real API keys.

# ---------------------------------------------------------------------------
# Local app data
# ---------------------------------------------------------------------------

# Local cockpit state directory. Defaults to ~/.wechat-radar.
WECHAT_RADAR_DATA_DIR=

# Use demo data. Defaults to 0. Set to 1 only for demo mode.
WECHAT_RADAR_DEMO=0

# Allow demo seeding to overwrite an existing config. Defaults to 0.
# Use only with a demo-only WECHAT_RADAR_DATA_DIR.
WECHAT_RADAR_ALLOW_DEMO_OVERWRITE=0

# Data source. Defaults to db. Set to wx only for legacy wx-cli/wx-daemon mode.
# Allowed: db, wx
WECHAT_RADAR_DATA_SOURCE=db

# Comma-separated names used to detect @me / mentions.
# Example: WECHAT_RADAR_MY_NAMES=Your Name,Alias
WECHAT_RADAR_MY_NAMES=

# Your own wxid. Used by decrypted DB adapters and lab identity checks.
WECHAT_RADAR_SELF_WXID=

# ---------------------------------------------------------------------------
# Hermes wechat-assistant paths
# ---------------------------------------------------------------------------

# Hermes work directory. Defaults to ~/wechat-assistant.
WECHAT_RADAR_WECHAT_ASSISTANT_DIR=

# Explicit collector DB path. Defaults to $WECHAT_RADAR_WECHAT_ASSISTANT_DIR/collector.db.
WECHAT_RADAR_COLLECTOR_DB=

# Explicit decrypted DB directory. Defaults to $WECHAT_RADAR_WECHAT_ASSISTANT_DIR/decrypted.
WECHAT_RADAR_DECRYPTED_DIR=

# Legacy/profile helper work directory. Defaults to ~/wechat-assistant.
WECHAT_RADAR_ASSISTANT_WORK_DIR=

# Optional override for /lab profile JSON.
# Defaults to profile JSON under the assistant work directory.
WECHAT_RADAR_LAB_PROFILE_JSON=

# Optional override for /lab assistant.db.
# Defaults to assistant.db under the assistant work directory.
WECHAT_RADAR_LAB_ASSISTANT_DB=

# ---------------------------------------------------------------------------
# /lab LLM provider
# ---------------------------------------------------------------------------

# Lab provider. Defaults to codex.
# Common values: codex, openai-compatible, local.
# Example for MiMo/GLM-compatible endpoints: openai-compatible
WECHAT_RADAR_LAB_PROVIDER=

# OpenAI-compatible or local base URL.
# Examples: https://api.example.com/v1, https://open.bigmodel.cn/api/paas/v4
WECHAT_RADAR_LAB_BASE_URL=

# API key for openai-compatible providers.
# Example placeholder: your-mimo-or-glm-key-here
WECHAT_RADAR_LAB_API_KEY=

# Lab model. Examples: glm-4-flash, mimo-vl, your-local-model.
WECHAT_RADAR_LAB_MODEL=glm-4-flash

# Max tokens for /lab openai-compatible responses. Defaults to 1800.
WECHAT_RADAR_LAB_MAX_TOKENS=1800

# Timeout for /lab provider calls in ms. Also reused by topic/link pipelines unless overridden.
# Defaults: 60000 for HTTP, 300000 for Codex fallback when WECHAT_RADAR_CODEX_TIMEOUT_MS is unset.
WECHAT_RADAR_LAB_CODEX_TIMEOUT_MS=180000

# Codex CLI fallback model and timeout. Used when provider=codex or as fallback model input.
WECHAT_RADAR_CODEX_MODEL=
WECHAT_RADAR_CODEX_TIMEOUT_MS=300000

# ---------------------------------------------------------------------------
# Topic aggregation LLM
# ---------------------------------------------------------------------------

# Optional overrides. If empty, topic aggregation reuses WECHAT_RADAR_LAB_BASE_URL/API_KEY/MODEL.
WECHAT_RADAR_TOPIC_BASE_URL=
# Example placeholder: your-topic-provider-key-here
WECHAT_RADAR_TOPIC_API_KEY=
WECHAT_RADAR_TOPIC_MODEL=

# Topic chunk size. Defaults to 120 messages.
WECHAT_RADAR_TOPIC_CHUNK_SIZE=120

# Topic LLM response token budget. Defaults to 6000.
WECHAT_RADAR_TOPIC_MAX_TOKENS=6000

# Topic worker concurrency. Defaults to 4.
WECHAT_RADAR_TOPIC_CONCURRENCY=4

# Topic retry count. Defaults to 3.
WECHAT_RADAR_TOPIC_RETRIES=3

# Topic call timeout in ms. Defaults to WECHAT_RADAR_LAB_CODEX_TIMEOUT_MS or 180000.
WECHAT_RADAR_TOPIC_TIMEOUT_MS=180000

# Default recent-day window for automatic topic/link rescans. Defaults to 31.
WECHAT_RADAR_AUTO_TOPIC_DAYS=31

# ---------------------------------------------------------------------------
# Link title/dedupe LLM
# ---------------------------------------------------------------------------

# Link LLM uses WECHAT_RADAR_TOPIC_BASE_URL/API_KEY/MODEL first, then WECHAT_RADAR_LAB_*.

# Link LLM response token budget. Defaults to 2400.
WECHAT_RADAR_LINK_MAX_TOKENS=2400

# Link LLM timeout in ms. Defaults to WECHAT_RADAR_LAB_CODEX_TIMEOUT_MS or 120000.
WECHAT_RADAR_LINK_LLM_TIMEOUT_MS=120000

# Link title batch size. Defaults to 40.
WECHAT_RADAR_LINK_BATCH_SIZE=40
